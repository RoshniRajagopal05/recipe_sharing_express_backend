<div class="center-box">
    <h2>User Listing 👥</h2>

    <table>
        <tr>
            <th>Username</th>
            <th>Email</th>
            <th>Status</th>
            <th>Actions</th>
        </tr>

        <% users.forEach(user => { %>
            <tr>
                <td><%= user.username %></td>
                <td><%= user.email %></td>
                <td>
                    <%= user.isActive ? "Active" : "Blocked" %>
                </td>

                <td>
                    <!-- 👁️ View Recipes -->
                    <a href="/admin/recipelisting/<%= user._id %>" class="btn-view">View</a>

                    <!-- 🚫 Block / Unblock -->
                    <% if (user.isActive) { %>
                        <a href="/admin/block-user/<%= user._id %>" class="btn-block">Block</a>
                    <% } else { %>
                        <a href="/admin/unblock-user/<%= user._id %>" class="btn-unblock">Unblock</a>
                    <% } %>
                </td>
            </tr>
        <% }) %>
    </table>
</div>